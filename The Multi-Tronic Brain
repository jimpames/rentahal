    {"x": 0, "y": 0},  # Starting point
    {"x": 10, "y": 0},  # First waypoint
    {"x": 10, "y": 10},  # Second waypoint
    {"x": 0, "y": 10},  # Third waypoint
]

# Initialize the patrol AI sentry's state
sentry_state = {
    "current_position": {"x": 0, "y": 0},
    "target_position": patrol_points[1],
    "on_watch": True,
    "intent": "patrol",
    "relieved": False,
}

# Scalar-vector control to adjust position
def calculate_vector(current, target):
    """Calculate movement vector between current and target points."""
    dx = target["x"] - current["x"]
    dy = target["y"] - current["y"]
    distance = math.sqrt(dx**2 + dy**2)
    if distance == 0:
        return {"dx": 0, "dy": 0}
    return {"dx": dx / distance, "dy": dy / distance}

# Patrol action based on current intent
def patrol_action():
    current = sentry_state["current_position"]
    target = sentry_state["target_position"]
    
    # Calculate movement vector
    move_vector = calculate_vector(current, target)
    
    # Simulate patrol movement by adjusting current position
    movement_speed = 1  # Units per update
    current["x"] += move_vector["dx"] * movement_speed
    current["y"] += move_vector["dy"] * movement_speed
    
    # Check if the sentry has reached the target position
    if abs(current["x"] - target["x"]) < 1 and abs(current["y"] - target["y"]) < 1:
        next_patrol_point()

# Move to the next patrol point in the boundary
def next_patrol_point():
    current_index = patrol_points.index(sentry_state["target_position"])
    next_index = (current_index + 1) % len(patrol_points)  # Loop back to start
    sentry_state["target_position"] = patrol_points[next_index]

# Simulate vigilance while patrolling
def sentry_watch():
    sentry_state["on_watch"] = True if random.choice([True, False]) else False

# Relieve the sentry from duty
def relieve_sentry():
    sentry_state["intent"] = "standby"
    sentry_state["relieved"] = True

# API to update the patrol intent and check for sentry status
@app.get("/sentry-status/")
def get_sentry_status():
    return {
        "position": sentry_state["current_position"],
        "intent": sentry_state["intent"],
        "on_watch": sentry_state["on_watch"],
        "relieved": sentry_state["relieved"],
    }

# Main patrol loop
@app.get("/patrol/")
def patrol():
    if sentry_state["intent"] == "patrol" and not sentry_state["relieved"]:
        patrol_action()  # Move the sentry
        sentry_watch()   # Check if sentry is on watch
