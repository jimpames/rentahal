import math

# Patrol points define the geoboundary
patrol_points = [
    {"x": 0, "y": 0},    # Starting point
    {"x": 10, "y": 0},   # First patrol waypoint
    {"x": 10, "y": 10},  # Second patrol waypoint
    {"x": 0, "y": 10},   # Third patrol waypoint
]

# Initialize the AI's state with intent to patrol
ai_state = {
    "current_position": {"x": 0, "y": 0},
    "target_position": patrol_points[1],
    "intent": "patrol",   # The AI's current mission intent
    "on_watch": True,
    "relieved": False,
}

# Scalar-Vector Calculation for movement between reality frames
def calculate_vector(current, target):
    """Calculate the movement vector from current to target position."""
    dx = target["x"] - current["x"]
    dy = target["y"] - current["y"]
    distance = math.sqrt(dx**2 + dy**2)
    return {"dx": dx / distance, "dy": dy / distance, "distance": distance}

# Execute patrol intent by moving toward the target patrol point
def execute_patrol():
    """Advance AI based on patrol intent and current position."""
    if ai_state["intent"] == "patrol":
        current = ai_state["current_position"]
        target = ai_state["target_position"]
        
        # Calculate movement vector
        vector = calculate_vector(current, target)
        
        # Move by adjusting current position based on the vector
        speed = 1  # Movement speed
        current["x"] += vector["dx"] * speed
        current["y"] += vector["dy"] * speed
        
        # Check if AI reached the patrol point and update if necessary
        if vector["distance"] < 1:
            update_patrol_target()

# Update patrol point to next one in the geoboundary loop
def update_patrol_target():
    """Move to the next patrol point in the geoboundary."""
    current_index = patrol_points.index(ai_state["target_position"])
    next_index = (current_index + 1) % len(patrol_points)
    ai_state["target_position"] = patrol_points[next_index]

# Execute AI behavior in real-time, including vigilance
def patrol_loop():
    while not ai_state["relieved"]:
        execute_patrol()
        print(f"Current Position: {ai_state['current_position']}, Vigilance: {ai_state['on_watch']}")

# Example of running the patrol
patrol_loop()
